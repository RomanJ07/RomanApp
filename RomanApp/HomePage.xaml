<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RomanApp.HomePage"
             Title="Accueil Pokemon"
             BackgroundColor="#FFFFFF">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="24,24,24,12" Spacing="24">
            
            <!-- Titre Principal et Sous-titre -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="Pokédex Master"
                       FontSize="36"
                       FontAttributes="Bold"
                       TextColor="#DC143C"
                       HorizontalTextAlignment="Center"/>
                
                <Label Text="Attrape-les tous !"
                       FontSize="18"
                       TextColor="#FFD700"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- Deux images côte à côte -->
            <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
                <Image Source="pokemon.png"
                       WidthRequest="120"
                       HeightRequest="120"
                       Aspect="AspectFit" />
                
                <Image Source="pikachu.png"
                       WidthRequest="120"
                       HeightRequest="120"
                       Aspect="AspectFit" />
            </HorizontalStackLayout>

            <Button Text="Voir l'action ⚡"
                    FontSize="18"
                    FontAttributes="Bold"
                    BackgroundColor="#DC143C"
                    TextColor="#FFFFFF"
                    CornerRadius="10"
                    Padding="16,12"
                    Clicked="OnSeeActionClicked"
                    HorizontalOptions="Center"
                    WidthRequest="280"/>

            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="1" Spacing="0" Padding="0" VerticalOptions="End">

            <WebView
                x:Name="PokeBallWebView"
                HeightRequest="320"
                WidthRequest="320"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="0,0,0,-8" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>

