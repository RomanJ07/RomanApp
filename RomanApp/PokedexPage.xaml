<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:RomanApp.Models"
             xmlns:viewModels="clr-namespace:RomanApp.ViewModels"
             x:Class="RomanApp.PokedexPage"
             x:DataType="viewModels:PokedexViewModel"
             Title="Pokedex">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
          Padding="24"
          RowSpacing="12">

        <Image Grid.Row="0"
               Source="pokemon_pokedex.png"
               HeightRequest="120"
               Aspect="AspectFit" />

        <Label Grid.Row="1"
               Text="Pokedex"
               FontSize="28"
               FontAttributes="Bold" />

        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#512BD4" />

        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Pokemons}"
                        SelectedItem="{Binding SelectedPokemon, Mode=TwoWay}"
                        SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PokemonListItem">
                    <Grid Padding="8"
                          ColumnDefinitions="72,*">
                        <Image Grid.Column="0"
                               WidthRequest="56"
                               HeightRequest="56"
                               Aspect="AspectFit"
                               Source="{Binding ImageUrl}" />
                        <Label Grid.Column="1"
                               VerticalOptions="Center"
                               FontSize="18"
                               Text="{Binding DisplayName}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="4"
                             Spacing="8"
                             IsVisible="{Binding HasSelectedPokemon}">
            <Label Text="Detail"
                   FontSize="22"
                   FontAttributes="Bold" />

            <Label Text="{Binding SelectedPokemonDetail.DisplayName}"
                   FontSize="20"
                   FontAttributes="Bold" />

            <Image Source="{Binding SelectedPokemonDetail.ImageUrl}"
                   HeightRequest="120"
                   Aspect="AspectFit" />

            <Label Text="{Binding SelectedPokemonDetail.Description}"
                   FontSize="14"
                   LineBreakMode="WordWrap" />
        </VerticalStackLayout>

        <Label Grid.RowSpan="5"
               VerticalOptions="End"
               HorizontalOptions="Center"
               TextColor="Red"
               FontSize="13"
               Text="{Binding ErrorMessage}"
               IsVisible="{Binding HasError}" />

    </Grid>

</ContentPage>

