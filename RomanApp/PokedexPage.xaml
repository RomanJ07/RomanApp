<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RomanApp.PokedexPage"
             Title="Pokedex">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Image Source="pokemon_pokedex.png"
                   HeightRequest="160"
                   Aspect="AspectFit" />

            <Label Text="Pokedex"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Label Text="Ajoute ici la liste de tes Pokemon preferes."
                   FontSize="16" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

