<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:RomanApp.Models"
             xmlns:viewModels="clr-namespace:RomanApp.ViewModels"
             x:Class="RomanApp.DresseurPage"
             x:DataType="viewModels:DresseurViewModel"
             Title="Dresseur"
             BackgroundColor="#FFF8E7">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Border StrokeShape="RoundRectangle 18"
                    Stroke="#D63A3A"
                    StrokeThickness="2"
                    BackgroundColor="#FFFFFF"
                    Padding="16">
                <Border.Shadow>
                    <Shadow Brush="#50000000" Radius="10" Offset="0,6" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="6">
                    <Label Text="Team Builder"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#1F356E" />
                    <Label Text="Cherche un Pokemon et ajoute-le dans ton equipe (6 max)."
                           FontSize="14"
                           TextColor="#555555" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 16"
                    Stroke="#FFCB05"
                    StrokeThickness="2"
                    BackgroundColor="#FFFFFF"
                    Padding="12">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Entry Grid.Column="0"
                               Placeholder="Ex: pikachu"
                               Text="{Binding SearchQuery}" />
                        <Button Grid.Column="1"
                                Text="Rechercher"
                                BackgroundColor="#2A75BB"
                                TextColor="White"
                                CornerRadius="10"
                                Command="{Binding SearchPokemonCommand}" />
                    </Grid>

                    <CollectionView ItemsSource="{Binding SearchResults}"
                                    SelectionMode="None"
                                    HeightRequest="200">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:PokemonListItem">
                                <Border Margin="0,4"
                                        Padding="8"
                                        Stroke="#EFEFEF"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="#FAFAFA">
                                    <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="10">
                                        <Image Grid.Column="0"
                                               Source="{Binding ImageUrl}"
                                               HeightRequest="48"
                                               WidthRequest="48" />
                                        <Label Grid.Column="1"
                                               VerticalOptions="Center"
                                               FontAttributes="Bold"
                                               Text="{Binding DisplayName}" />
                                        <Button Grid.Column="2"
                                                Text="Ajouter"
                                                Padding="10,6"
                                                BackgroundColor="#D63A3A"
                                                TextColor="White"
                                                CornerRadius="10"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:DresseurViewModel}}, Path=AddPokemonCommand}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding TeamSlots}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="10" HorizontalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TrainerTeamSlot">
                        <Border Padding="12"
                                StrokeShape="RoundRectangle 16"
                                Stroke="#1F356E"
                                BackgroundColor="White"
                                MinimumHeightRequest="165">
                            <Border.Shadow>
                                <Shadow Brush="#30000000" Radius="8" Offset="0,4" />
                            </Border.Shadow>

                            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                                <Label Text="{Binding SlotNumber, StringFormat='Slot {0}'}"
                                       FontAttributes="Bold"
                                       TextColor="#1F356E" />

                                <VerticalStackLayout Grid.Row="1" Spacing="6">
                                    <Image HeightRequest="72"
                                           Source="{Binding PokemonImageUrl}" />
                                    <Label Text="{Binding PokemonDisplayName}"
                                           HorizontalTextAlignment="Center"
                                           FontAttributes="Bold" />
                                </VerticalStackLayout>

                                <Button Grid.Row="2"
                                        Text="Retirer"
                                        BackgroundColor="#F15B5B"
                                        TextColor="White"
                                        CornerRadius="10"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:DresseurViewModel}}, Path=RemovePokemonCommand}"
                                        CommandParameter="{Binding .}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button"
                                                     Binding="{Binding IsEmpty}"
                                                     Value="True">
                                            <Setter Property="IsVisible" Value="False" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border StrokeShape="RoundRectangle 16"
                    Stroke="#1F356E"
                    BackgroundColor="#FFFFFF"
                    Padding="14">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                    <Label Grid.ColumnSpan="2"
                           Text="Analyse de l'equipe"
                           FontAttributes="Bold"
                           FontSize="18"
                           TextColor="#1F356E" />
                    <Label Grid.Row="1" Text="HP total" FontAttributes="Bold" />
                    <Label Grid.Row="1" Grid.Column="1"
                           HorizontalTextAlignment="End"
                           Text="{Binding TotalHp}" />
                    <Label Grid.Row="2" Text="Attaque totale" FontAttributes="Bold" />
                    <Label Grid.Row="2" Grid.Column="1"
                           HorizontalTextAlignment="End"
                           Text="{Binding TotalAttack}" />
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="Sauvegarder l'equipe"
                        BackgroundColor="#2A75BB"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        IsEnabled="{Binding HasAtLeastOneMember}"
                        Command="{Binding SaveTeamCommand}" />

                <Button Grid.Column="1"
                        Text="Vider l'equipe"
                        BackgroundColor="#F15B5B"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        IsEnabled="{Binding HasAtLeastOneMember}"
                        Command="{Binding ClearTeamCommand}" />
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#D63A3A"
                               HorizontalOptions="Center" />

            <Label Text="{Binding StatusMessage}"
                   TextColor="#555555"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>


