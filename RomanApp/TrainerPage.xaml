<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RomanApp.TrainerPage"
             Title="Dresseur">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Image Source="pokemon_trainer.svg"
                   HeightRequest="160"
                   Aspect="AspectFit" />

            <Label Text="Profil Dresseur"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Label Text="Affiche le nom, badges et progression du dresseur."
                   FontSize="16" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

