<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:RomanApp.ViewModels"
             xmlns:converters="clr-namespace:RomanApp.Converters"
             x:Class="RomanApp.AddPokemonPage"
             x:DataType="viewModels:AddPokemonViewModel"
             Title="Capturer un Pokémon"
             BackgroundColor="#000000">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:BytesToImageSourceConverter x:Key="BytesToImageSourceConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            
            <!-- Titre de la page -->
            <Label Text="Capturer un Pokémon"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#DC143C"
                   HorizontalTextAlignment="Center"/>

            <!-- Section Photo -->
            <Frame Padding="16" CornerRadius="15" BackgroundColor="#1a1a1a" HasShadow="True">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <!-- Affichage de la photo prise -->
                    <Image x:Name="PhotoImage"
                           HeightRequest="250"
                           WidthRequest="250"
                           Aspect="AspectFill"
                           Source="{Binding PhotoData, Converter={StaticResource BytesToImageSourceConverter}}"
                           IsVisible="{Binding IsPhotoTaken}"/>

                    <!-- Message si pas de photo -->
                    <Label Text="Aucune photo prise"
                           FontSize="16"
                           TextColor="#CCCCCC"
                           HorizontalTextAlignment="Center"
                           IsVisible="{Binding IsPhotoTaken, Converter={StaticResource InvertedBoolConverter}}"/>

                    <!-- Bouton pour prendre une photo -->
                    <Button Text="📷 Prendre une photo"
                            FontSize="16"
                            FontAttributes="Bold"
                            BackgroundColor="#DC143C"
                            TextColor="#FFFFFF"
                            CornerRadius="10"
                            Padding="16,12"
                            Command="{Binding TakePhotoCommand}"
                            HorizontalOptions="Center"
                            WidthRequest="220"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Section Titre -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Titre du Pokémon"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#FFFFFF"/>
                <Frame Padding="0" BorderColor="#333333" CornerRadius="8" HasShadow="False" BackgroundColor="#1a1a1a">
                    <Entry x:Name="TitleEntry"
                           Placeholder="Ex: Mon Pikachu préféré"
                           FontSize="14"
                           Text="{Binding Title}"
                           BackgroundColor="#1a1a1a"
                           TextColor="#FFFFFF"
                           PlaceholderColor="#999999"
                           Margin="12"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Section Description -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Description"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#FFFFFF"/>
                <Frame Padding="0" BorderColor="#333333" CornerRadius="8" HasShadow="False" BackgroundColor="#1a1a1a">
                    <Editor x:Name="DescriptionEditor"
                            Placeholder="Décrivez le Pokémon capturé..."
                            FontSize="14"
                            Text="{Binding Description}"
                            BackgroundColor="#1a1a1a"
                            TextColor="#FFFFFF"
                            PlaceholderColor="#999999"
                            HeightRequest="120"
                            Margin="12"/>
                </Frame>
            </VerticalStackLayout>

            <!-- Boutons d'action -->
            <VerticalStackLayout Spacing="12">
                <!-- Bouton Ajouter -->
                <Button Text="✅ Ajouter au Pokédex"
                        FontSize="16"
                        FontAttributes="Bold"
                        BackgroundColor="#FFD700"
                        TextColor="#000000"
                        CornerRadius="10"
                        Padding="16,12"
                        Command="{Binding AddPokemonCommand}"
                        HorizontalOptions="FillAndExpand"/>

                <!-- Bouton Réinitialiser -->
                <Button Text="🔄 Réinitialiser"
                        FontSize="14"
                        BackgroundColor="#E0E0E0"
                        TextColor="#333333"
                        CornerRadius="10"
                        Padding="16,12"
                        Command="{Binding ResetFormCommand}"
                        HorizontalOptions="FillAndExpand"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>




