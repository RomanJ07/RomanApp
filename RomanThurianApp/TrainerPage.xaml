<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:RomanThurianApp.Models"
             xmlns:viewModels="clr-namespace:RomanThurianApp.ViewModels"
             x:Class="RomanThurianApp.TrainerPage"
             x:DataType="viewModels:TrainerViewModel"
             Title="Dresseur"
             BackgroundColor="#FFF8E7">

    <ContentPage.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="StrokeShape" Value="RoundRectangle 16" />
            <Setter Property="BackgroundColor" Value="#FFFFFF" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#2A75BB" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontAttributes" Value="Bold" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#F15B5B" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontAttributes" Value="Bold" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="Label">
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="#1F356E" />
        </Style>

        <DataTemplate x:Key="SearchItemTemplate" x:DataType="models:PokemonListItem">
            <Border Margin="0,4" Padding="8" Stroke="#EFEFEF" StrokeShape="RoundRectangle 12" BackgroundColor="#FAFAFA">
                <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="10">
                    <Image Grid.Column="0" Source="{Binding ImageUrl}" HeightRequest="48" WidthRequest="48" />
                    <Label Grid.Column="1" VerticalOptions="Center" FontAttributes="Bold" Text="{Binding DisplayName}" />
                    <Button Grid.Column="2"
                            Text="Ajouter"
                            Padding="10,6"
                            BackgroundColor="#D63A3A"
                            TextColor="White"
                            CornerRadius="10"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TrainerViewModel}}, Path=AddPokemonCommand}"
                            CommandParameter="{Binding .}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TeamSlotTemplate" x:DataType="models:TrainerTeamSlot">
            <Border Padding="12" Stroke="#1F356E" StrokeShape="RoundRectangle 16" BackgroundColor="White" MinimumHeightRequest="165">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                    <Label Text="{Binding SlotNumber, StringFormat='Slot {0}'}" FontAttributes="Bold" TextColor="#1F356E" />
                    <VerticalStackLayout Grid.Row="1" Spacing="6">
                        <Image HeightRequest="72" Source="{Binding PokemonImageUrl}" />
                        <Label Text="{Binding PokemonDisplayName}" HorizontalTextAlignment="Center" FontAttributes="Bold" />
                    </VerticalStackLayout>
                    <Button Grid.Row="2"
                            Text="Retirer"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TrainerViewModel}}, Path=RemovePokemonCommand}"
                            CommandParameter="{Binding .}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsEmpty}" Value="True">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TypeItemTemplate" x:DataType="models:TeamTypeCountItem">
            <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                <Label Text="{Binding TypeName}" />
                <Label Grid.Column="1" FontAttributes="Bold" Text="{Binding Count, StringFormat='x{0}'}" />
            </Grid>
        </DataTemplate>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Border Style="{StaticResource CardBorderStyle}" Stroke="#D63A3A" StrokeThickness="2" Padding="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Team Builder" FontSize="28" Style="{StaticResource SectionTitleStyle}" />
                    <Label Text="Cherche un Pokemon et ajoute-le dans ton equipe (6 max)." FontSize="14" TextColor="#555555" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Stroke="#FFCB05" StrokeThickness="2">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Entry Grid.Column="0" Placeholder="Ex: pikachu" Text="{Binding SearchQuery}" />
                        <Button Grid.Column="1"
                                Text="Rechercher"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SearchPokemonCommand}" />
                    </Grid>
                    <CollectionView ItemsSource="{Binding SearchResults}" SelectionMode="None" HeightRequest="200" ItemTemplate="{StaticResource SearchItemTemplate}" />
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding TeamSlots}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" VerticalItemSpacing="10" HorizontalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <StaticResource Key="TeamSlotTemplate" />
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border Style="{StaticResource CardBorderStyle}" Stroke="#1F356E" Padding="14">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Analyse de l'equipe" Style="{StaticResource SectionTitleStyle}" FontSize="18" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                        <Label Grid.Row="0" Text="Membres" FontAttributes="Bold" />
                        <Label Grid.Row="0" Grid.Column="1" HorizontalTextAlignment="End" Text="{Binding CurrentTeamCount}" />

                        <Label Grid.Row="1" Text="Emplacements vides" FontAttributes="Bold" />
                        <Label Grid.Row="1" Grid.Column="1" HorizontalTextAlignment="End" Text="{Binding EmptySlotsCount}" />

                        <Label Grid.Row="2" Text="HP total" FontAttributes="Bold" />
                        <Label Grid.Row="2" Grid.Column="1" HorizontalTextAlignment="End" Text="{Binding TotalHp}" />

                        <Label Grid.Row="3" Text="Attaque totale" FontAttributes="Bold" />
                        <Label Grid.Row="3" Grid.Column="1" HorizontalTextAlignment="End" Text="{Binding TotalAttack}" />
                    </Grid>

                    <Label Text="Repartition des types" Style="{StaticResource SectionTitleStyle}" />

                    <CollectionView ItemsSource="{Binding TypeDistribution}" SelectionMode="None" HeightRequest="140" ItemTemplate="{StaticResource TypeItemTemplate}" />

                    <Label Text="Ajoute des Pokemon pour voir leurs types." TextColor="#777777" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="Sauvegarder l'equipe"
                        Style="{StaticResource PrimaryButtonStyle}"
                        CornerRadius="12"
                        IsEnabled="{Binding HasAtLeastOneMember}"
                        Command="{Binding SaveTeamCommand}" />

                <Button Grid.Column="1"
                        Text="Vider l'equipe"
                        Style="{StaticResource DangerButtonStyle}"
                        CornerRadius="12"
                        IsEnabled="{Binding HasAtLeastOneMember}"
                        Command="{Binding ClearTeamCommand}" />
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#D63A3A"
                               HorizontalOptions="Center" />

            <Label Text="{Binding StatusMessage}"
                   TextColor="#555555"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

