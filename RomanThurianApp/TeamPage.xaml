<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RomanThurianApp.TeamPage"
             Title="Equipe">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Image Source="pokemon_team.png"
                   HeightRequest="160"
                   Aspect="AspectFit" />

            <Label Text="Mon equipe"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Label Text="Construis ton equipe de 6 Pokemon ici."
                   FontSize="16" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

